{
  "version": 2,
  "builds": [
    {
      "src": "backend/app/core/app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/app/core/app.py"
    },
    {
      "src": "/(.*)",
      "dest": "backend/app/core/app.py"
    }
  ],
  "env": {
    "ENVIRONMENT": "production",
    "DEBUG": "false",
    "HEDERA_NETWORK": "testnet",
    "JWT_SECRET_KEY": "hackathon_jwt_secret_2024",
    "DATABASE_URL": "sqlite:///./hedera_flow.db",
    "REDIS_URL": "redis://localhost:6379",
    "CORS_ORIGINS": "https://*.vercel.app,http://localhost:5173"
  }
}